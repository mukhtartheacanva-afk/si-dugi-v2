// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  }

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Ini adalah "cetak biru" tabel lo
model Siswa {
  id        Int      @id @default(autoincrement())
  nama      String
  kelas     String
  status    String   @default("Aktif")
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  role      String   @default("USER") // Nanti isinya "ADMIN" atau "USER"
  createdAt DateTime @default(now())
}

model Materi {
  id          Int      @id @default(autoincrement())
  judul       String
  kategori    String
  urlYoutube  String
  deskripsi   String?
  createdAt   DateTime @default(now())
}

// Model untuk Kumpulan Peraturan
model Regulation {
  id          String   @id @default(cuid())
  title       String   // Judul Peraturan
  description String?  // Hapus @db.Text, SQLite otomatis handle teks panjang
  category    String   // Contoh: "Undang-Undang", "Peraturan Daerah"
  fileUrl     String   // Lokasi simpan file PDF
  fileName    String   // Nama asli file untuk download
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([title])
}
